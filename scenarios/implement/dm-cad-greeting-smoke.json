{
  "name": "dm-cad-greeting-smoke",
  "description": "CADExpert DM greeting (requires CAD pack).",
  "tags": ["pack-smoke", "dm", "cad"],
  "optional": true,
  "target_agent": "CADExpert",
  "required_packs": ["cad"],
  "steps": [
    {
      "action": "send",
      "content": "Hello — what can you help me design?"
    },
    {
      "action": "wait_reply",
      "from": "CADExpert",
      "timeout": "120s"
    },
    {
      "action": "assert_messages",
      "from": "CADExpert",
      "last_reply_only": true,
      "any_match": ["OpenSCAD", "CAD", "model", "design", "parametric"]
    }
  ]
}
