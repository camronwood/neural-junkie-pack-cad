{
  "name": "cad-design-render-export-smoke",
  "description": "Design → render → printability → export STL for print.",
  "tags": ["cad", "collab", "pack-smoke"],
  "channel": "collab-scenarios",
  "agents": "@CADExpert @ManufacturingExpert",
  "required_agents": ["CADExpert", "ManufacturingExpert"],
  "required_packs": ["cad"],
  "workspace": {
    "fixture": "minimal-repo",
    "workspace_flag": true,
    "outline": true,
    "file_tree": "README.md\nexports/\n"
  },
  "collaborate": {
    "flags": ["--workspace", "--rounds", "1", "--messages", "10"],
    "goal": "Design a parametric phone stand in OpenSCAD. @CADExpert write the SCAD, render STL, and save to the workspace. @ManufacturingExpert run a printability check on the STL and export a copy to exports/phone-stand.stl for FDM printing."
  },
  "steps": [
    {
      "action": "wait_phase",
      "phase": "planning",
      "timeout": 60
    },
    {
      "action": "wait_discussion",
      "min_total": 2,
      "min_per_agent": 1,
      "required_agents": ["CADExpert", "ManufacturingExpert"],
      "timeout": "180s"
    },
    {
      "action": "assert_plan",
      "min_tasks": 2,
      "max_tasks": 8,
      "tasks_have_assignee": true,
      "content_any_match": ["openscad|scad|design", "print|stl|export|manufacturing"]
    },
    {
      "action": "approve_plan"
    },
    {
      "action": "wait_phase",
      "phase": "executing",
      "timeout": "240s"
    }
  ],
  "cleanup": "clear"
}
